# .env
# Variables de entorno del proyecto

# =============================================
# BASE DE DATOS
# =============================================
DB_NAME=contable.db

# =============================================
# CARPETA DE SUBIDA
# =============================================
UPLOAD_FOLDER=data/pdfs
MAX_FILE_SIZE=52428800

# =============================================
# EMAIL - NOTIFICACIONES (OPCIONAL)
# =============================================
# Configuración SMTP para enviar notificaciones por email
# Para Gmail: usa una "Contraseña de aplicación"
# https://myaccount.google.com/apppasswords

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Email desde el que se enviarán las notificaciones
EMAIL_ORIGEN=tu_correo@gmail.com

# Contraseña de aplicación de Gmail (NO tu contraseña normal)
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# Email que recibirá las notificaciones
EMAIL_DESTINO=tu_correo_destino@gmail.com

# =============================================
# SEGURIDAD (OPCIONAL)
# =============================================
# SECRET_KEY=tu_clave_secreta_aqui
# DEBUG=False